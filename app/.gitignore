# Flutter / Dart
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
pubspec.lock
build/

# Generated platform files (regenerated by flutter create in CI)
# Keep: android/, ios/, macos/, windows/, linux/ — they contain custom code
# Ignore generated Xcode user data
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcshareddata/WorkspaceSettings.xcsettings

# Android generated
android/local.properties
android/.gradle/
android/key.properties
android/keystore.jks
android/app/google-services.json

# iOS / macOS CocoaPods
ios/Pods/
macos/Pods/
ios/Flutter/flutter_export_environment.sh
macos/Flutter/flutter_export_environment.sh

# IDE
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.swp
.DS_Store

# sing-box binary (downloaded by CI; too large to commit)
assets/cores/sing-box
assets/cores/sing-box.exe
